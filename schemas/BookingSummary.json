{
  "$ref": "#/definitions/BookingSummary",
  "definitions": {
    "BookingSummary": {
      "type": "object",
      "properties": {
        "bookings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "bookingDates": {
                "type": "object",
                "properties": {
                  "checkin": {
                    "type": "string",
                    "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                  },
                  "checkout": {
                    "$ref": "#/definitions/BookingSummary/properties/bookings/items/properties/bookingDates/properties/checkin"
                  }
                },
                "required": [
                  "checkin",
                  "checkout"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "bookingDates"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "bookings"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
