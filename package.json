{
  "name": "restful-booker-api-testing",
  "version": "0.1.0",
  "description": "Production-grade API test automation framework for the Restful Booker Platform microservices.",
  "author": "Andrii Kohut",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:unit": "vitest run --passWithNoTests tests/unit",
    "test:smoke": "vitest run --passWithNoTests tests/smoke",
    "test:regression": "vitest run --passWithNoTests tests/regression",
    "test:negative": "vitest run --passWithNoTests tests/negative",
    "test:contract": "vitest run --passWithNoTests tests/contract",
    "coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,mjs,cjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^16.6.1",
    "zod": "^3.25.76"
  }
}
