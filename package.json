{
  "name": "restful-booker-api-testing",
  "version": "0.1.0",
  "description": "Production-grade API test automation framework for the Restful Booker Platform microservices.",
  "author": "Andrii Kohut",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "HEALTHCHECK=1 vitest run",
    "test:watch": "HEALTHCHECK=1 vitest",
    "test:unit": "vitest run tests/unit",
    "test:smoke": "HEALTHCHECK=1 vitest run tests/smoke",
    "test:negative": "HEALTHCHECK=1 vitest run tests/negative",
    "test:contract": "HEALTHCHECK=1 vitest run tests/contract",
    "test:data-driven": "HEALTHCHECK=1 vitest run tests/data-driven",
    "test:property": "HEALTHCHECK=1 vitest run tests/property",
    "test:security": "HEALTHCHECK=1 vitest run tests/security",
    "test:pact": "rm -rf pacts && vitest run tests/pact",
    "test:live": "HEALTHCHECK=1 vitest run tests/smoke tests/contract tests/negative tests/data-driven tests/property tests/security",
    "coverage": "HEALTHCHECK=1 vitest run --coverage",
    "test:local": "ENV_FILE=.env.local HEALTHCHECK=1 vitest run --no-file-parallelism tests/smoke tests/contract tests/negative tests/data-driven tests/property tests/security",
    "coverage:local": "ENV_FILE=.env.local HEALTHCHECK=1 vitest run --coverage --no-file-parallelism",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down -v",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "pact:broker:up": "docker compose -f docker-compose.pact.yml up -d --wait",
    "pact:broker:down": "docker compose -f docker-compose.pact.yml down -v",
    "pact:publish": "tsx scripts/pact-broker.ts publish",
    "pact:verify": "ENV_FILE=.env.local tsx scripts/verify-providers.ts",
    "pact:can-i-deploy": "tsx scripts/pact-broker.ts can-i-deploy",
    "test:report": "HEALTHCHECK=1 ALLURE=1 vitest run",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "schema:export": "tsx scripts/export-schemas.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "diagnose:exchanges": "tsx scripts/summarize-exchanges.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@faker-js/faker": "^10.5.0",
    "@pact-foundation/pact": "^17.0.1",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "allure-commandline": "^2.43.0",
    "allure-vitest": "^3.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-check": "^4.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.19.0",
    "vitest": "^3.0.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "lint-staged": {
    "*.{ts,mjs,cjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "axios": "^1.18.1",
    "dotenv": "^16.6.1",
    "zod": "^3.25.76"
  }
}
